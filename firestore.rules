rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isUserInAgency(agencyId) {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return request.auth != null &&
             exists(userDocPath) &&
             'agencyId' in get(userDocPath).data &&
             get(userDocPath).data.agencyId == agencyId;
    }
    
    function isUserAdmin(agencyId) {
        let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
        return isUserInAgency(agencyId) &&
               'role' in get(userDocPath).data &&
               get(userDocPath).data.role == 'admin';
    }

    match /users/{userId} {
      allow get: if request.auth != null && (
        request.auth.uid == userId || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
          exists(/databases/$(database)/documents/users/$(userId)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId == get(/databases/$(database)/documents/users/$(userId)).data.agencyId
        )
      );
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow list, delete: if false;
    }

    match /agencies/{agencyId} {
      // Allow public read for agency branding on the public website.
      allow get: if true;
      
      // Only authenticated users can list all agencies.
      allow list: if request.auth != null;
      
      // Only admins of the agency can update its details.
      allow update: if isUserAdmin(agencyId);

      // Any authenticated user can create an agency.
      allow create: if request.auth != null;

      // Deleting agencies is not allowed from the client.
      allow delete: if false;
    }
    
    match /invites/{inviteId} {
        allow create: if isUserAdmin(request.resource.data.agencyId);
        allow read, delete: if request.auth != null;
    }
    
    match /agencies/{agencyId}/properties/{propertyId} {
        // GET rule: allow if user is in agency OR if property is public
        allow get: if isUserInAgency(agencyId) 
                    || (resource.data.visibility == 'Colaborare' && resource.data.status == 'Activ');

        // LIST rule: allow if user is in agency OR if they are a public (unauthenticated) user.
        // This is necessary for public queries to work. The security is enforced
        // by the GET rule on the server side for each document returned by the query.
        allow list: if isUserInAgency(agencyId) || request.auth == null;

        // WRITE rule: only members of the agency can write.
        allow write: if isUserInAgency(agencyId);
    }
    
    // For all other private subcollections, only allow access to agency members.
    match /agencies/{agencyId}/(contacts|tasks|reports|emails|contracts)/{docId} {
      allow read, write: if isUserInAgency(agencyId);
    }
  }
}
