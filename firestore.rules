/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model.
 * All data is isolated within a user's own data tree, ensuring that a user can only ever access
 * their own information. There is no concept of shared or public data in this model.
 *
 * This version simplifies the rules by using a wildcard match for all user subcollections,
 * ensuring consistent ownership-based security across all user-related data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ------------------------------------------------------------------------
    // User Profile Rules
    // ------------------------------------------------------------------------
    match /users/{userId} {
      // Users can read and update their own profile.
      allow get, update: if isOwner(userId);
      // Users can create their own profile document.
      allow create: if isOwner(userId);
      // Prevent listing all users for security.
      allow list: if false;
      // Prevent users from deleting their own root document.
      allow delete: if false;
    }

    // ------------------------------------------------------------------------
    // Generic Sub-collection Rules
    // This uses a wildcard to match all subcollections of a user (e.g., contacts, properties, tasks).
    // ------------------------------------------------------------------------
    match /users/{userId}/{collection}/{documentId} {
      // A user can perform any read or write operation on documents in their own subcollections.
      allow read, write: if isOwner(userId);
    }
  }
}
