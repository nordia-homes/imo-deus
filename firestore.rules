rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isUserAdmin() {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return request.auth != null &&
             exists(userDocPath) &&
             'role' in get(userDocPath).data &&
             get(userDocPath).data.role == 'admin';
    }
    
    function isUserAdminOfAgency(agencyId) {
        let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
        return request.auth != null &&
             exists(userDocPath) &&
             'role' in get(userDocPath).data &&
             get(userDocPath).data.role == 'admin' &&
             'agencyId' in get(userDocPath).data &&
             get(userDocPath).data.agencyId == agencyId;
    }


    match /users/{userId} {
      allow get: if request.auth != null && (
        request.auth.uid == userId ||
        (
          isUserAdmin() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId == get(/databases/$(database)/documents/users/$(userId)).data.agencyId
        )
      );

      allow list: if isUserAdmin();

      allow update, create: if request.auth != null && request.auth.uid == userId;
      
      allow delete: if false;
    }

    match /agencies/{agencyId} {
      allow get: if true;
      allow list: if request.auth != null;
      allow update: if isUserAdminOfAgency(agencyId);
      allow create: if request.auth != null;
      allow delete: if false;
    }
    
    match /invites/{inviteId} {
        allow create: if isUserAdminOfAgency(request.resource.data.agencyId);
        allow read, delete: if request.auth != null;
    }

    match /agencies/{agencyId}/{subcollection}/{docId} {
        allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId == agencyId;
    }
  }
}
