rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isUserInAgency(agencyId) {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return request.auth != null &&
             exists(userDocPath) &&
             'agencyId' in get(userDocPath).data &&
             get(userDocPath).data.agencyId == agencyId;
    }
    
    function isUserAdmin(agencyId) {
        let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
        return isUserInAgency(agencyId) &&
               'role' in get(userDocPath).data &&
               get(userDocPath).data.role == 'admin';
    }

    match /users/{userId} {
      // A user can get their own profile.
      // An admin can get profiles of users in their own agency.
      allow get: if request.auth != null && (
        request.auth.uid == userId || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
          exists(/databases/$(database)/documents/users/$(userId)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId == get(/databases/$(database)/documents/users/$(userId)).data.agencyId
        )
      );
        
      // A user can create and update their own profile.
      allow create, update: if request.auth != null && request.auth.uid == userId;
      
      // Nobody can list all users or delete users from the client.
      allow list, delete: if false;
    }

    match /agencies/{agencyId} {
      // Allow public read for branding on the public website.
      allow get: if true;
      
      // Only authenticated users can list all agencies (e.g. in a search).
      allow list: if request.auth != null;
      
      // Only admins of the agency can update its details.
      allow update: if isUserAdmin(agencyId);

      // Any authenticated user can create an agency.
      allow create: if request.auth != null;

      // Deleting agencies is not allowed from the client.
      allow delete: if false;
    }
    
    match /invites/{inviteId} {
        allow create: if isUserAdmin(request.resource.data.agencyId);
        allow read, delete: if request.auth != null;
    }
    
    match /agencies/{agencyId}/properties/{propertyId} {
        // Anyone can read a specific property if it's public.
        // Agency members can read any property in their agency.
        allow get: if (resource.data.visibility == 'Colaborare' && resource.data.status == 'Activ') || isUserInAgency(agencyId);
        
        // Anyone can list properties. This is required for the public website.
        // The more specific 'get' rule above will still be enforced for each document.
        allow list: if true;
        
        // Only agency members can write/edit/delete properties.
        allow create, update, delete: if isUserInAgency(agencyId);
    }
    
    // For all other private subcollections, only allow access to agency members.
    match /agencies/{agencyId}/(contacts|tasks|reports|emails|contracts)/{docId} {
      allow read, write: if isUserInAgency(agencyId);
    }
  }
}
