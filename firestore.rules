rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isUserInAgency(agencyId) {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return request.auth != null && exists(userDocPath) && get(userDocPath).data.agencyId == agencyId;
    }

    function isUserAdmin() {
      // The get() call will return null if the document does not exist,
      // and accessing .data.role will also result in a non-admin comparison.
      // This is safe and simpler.
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isUserAdminOfAgency(agencyId) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      // This is safe because if the document or fields don't exist, the comparisons will fail.
      return request.auth != null &&
             userData.agencyId == agencyId &&
             userData.role == 'admin';
    }


    match /users/{userId} {
      // GET: Allow reading own profile, or admin reading a user in their agency
      allow get: if request.auth != null && (
        request.auth.uid == userId ||
        (
          isUserAdmin() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId == resource.data.agencyId
        )
      );

      // LIST: An admin can list users. The 'get' rule will be enforced by Firestore on the query results.
      allow list: if isUserAdmin();

      // Keep write permissions the same: only for the user themselves
      allow update, create: if request.auth != null && request.auth.uid == userId;
      
      // Deletion remains disallowed
      allow delete: if false;
    }

    // Agencies can be read by anyone, but only modified by admins of that agency.
    match /agencies/{agencyId} {
      allow get: if true;
      allow list: if request.auth != null; // Allow logged-in users to list agencies
      // Only agency admins can update agency details.
      allow update: if isUserAdminOfAgency(agencyId);
      // Agency creation is handled by specific logic (e.g. in settings page)
      allow create: if request.auth != null;
      allow delete: if false; // Disallow direct deletion
    }
    
    // Invitation documents for new agents
    match /invites/{inviteId} {
        // An admin of an agency can create an invite
        allow create: if isUserAdminOfAgency(request.resource.data.agencyId);
        // Any authenticated user can read an invite (to check if they were invited)
        // and delete it after use. The client logic ensures they only access their own.
        allow read, delete: if request.auth != null;
    }

    // Secure all sub-collections within an agency.
    match /agencies/{agencyId}/{allPaths=**} {
      // Only users who are part of the agency can read and write its data.
      allow read, write: if request.auth != null && isUserInAgency(agencyId);
    }
  }
}
