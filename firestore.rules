rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Rules for the top-level 'users' collection.
    match /users/{userId} {
      // A user can get, create and update their own profile document.
      allow get, create, update: if request.auth != null && request.auth.uid == userId;
      // Main user document deletion is disallowed.
      allow delete: if false;

      // This recursive wildcard rule applies to ALL subcollections of a user document.
      // It ensures that a user can only read and write to their own data tree.
      // This secures 'contacts', 'properties', 'tasks', etc.
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
