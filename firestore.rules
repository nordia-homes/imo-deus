rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isUserInAgency(agencyId) {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return request.auth != null &&
             exists(userDocPath) &&
             'agencyId' in get(userDocPath).data &&
             get(userDocPath).data.agencyId == agencyId;
    }
    
    function isUserAdmin(agencyId) {
        let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
        return isUserInAgency(agencyId) &&
               'role' in get(userDocPath).data &&
               get(userDocPath).data.role == 'admin';
    }

    // A newly registered agent can add themselves to the agentIds array of their agency.
    // This is secure because:
    // 1. Their user document must already exist and have the correct agencyId (from the invite flow).
    // 2. The only change allowed is appending their own UID to the agentIds array.
    function isAddingSelfToAgency(agencyId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      // Check that the only field being changed is 'agentIds'
      let isUpdatingOnlyAgentIds = request.resource.data.diff(resource.data).affectedKeys().hasOnly(['agentIds']);
      // Check that the new agentIds array is exactly the old one plus the new user's UID
      let isAddingSelf = request.resource.data.agentIds == resource.data.agentIds.concat([request.auth.uid]);
      
      return request.auth.uid != null &&
             userDoc.agencyId == agencyId &&
             isUpdatingOnlyAgentIds &&
             isAddingSelf;
    }

    match /users/{userId} {
      allow get: if request.auth != null && (
        request.auth.uid == userId || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
          exists(/databases/$(database)/documents/users/$(userId)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId == get(/databases/$(database)/documents/users/$(userId)).data.agencyId
        )
      );
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow list, delete: if false;
    }

    match /agencies/{agencyId} {
      allow get: if true;
      allow list: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if false;
      allow update: if isUserAdmin(agencyId) || isAddingSelfToAgency(agencyId);
    }
    
    match /invites/{inviteId} {
        allow create: if isUserAdmin(request.resource.data.agencyId);
        allow read, delete: if request.auth != null;
    }
    
    match /agencies/{agencyId}/properties/{propertyId} {
        // --- Rules for Authenticated Agency Members ---
        // Allow agency members to perform any read/write operation.
        allow read, write: if isUserInAgency(agencyId);

        // --- Overriding Rules for Public Access ---
        // Allow unauthenticated list queries. The results are then checked by the `get` rule.
        allow list: if request.auth == null;
        
        // Allow unauthenticated get requests ONLY for public and active properties.
        allow get: if request.auth == null 
                     && resource.data.visibility == 'Colaborare' 
                     && resource.data.status == 'Activ';
    }
    
    // For all other private subcollections, only allow access to agency members.
    match /agencies/{agencyId}/(contacts|tasks|reports|emails|contracts)/{docId} {
      allow read, write: if isUserInAgency(agencyId);
    }
  }
}
