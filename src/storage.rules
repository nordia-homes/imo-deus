rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Public read access is allowed for all files.
    // This is necessary for images to be displayed in the app.
    // Write access is restricted to authenticated users.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
