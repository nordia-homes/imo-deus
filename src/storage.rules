rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Allow users to manage their own files (e.g. profile picture)
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow authenticated users to write property images within their agency
    match /agencies/{agencyId}/properties/{propertyId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId == agencyId;
    }

    // Allow agency admins to manage agent profile images inside their own agency
    match /agencies/{agencyId}/agents/{agentId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId == agencyId &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Allow agency members to work with contract templates and generated PDFs
    match /agencies/{agencyId}/contracts/{allPaths=**} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId == agencyId;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId == agencyId;
    }

    // Default deny all other writes, allow public reads for things like logos if not under a protected path
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false; // Deny by default for security
    }
  }
}
