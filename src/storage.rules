rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to check if the user belongs to the specified agency by reading their user profile.
    function isUserInAgency(agencyId) {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId == agencyId;
    }

    // Allow public read access to all files. This is generally safe for property images.
    match /{allPaths=**} {
      allow read: if true;
    }

    // Secure write rule for property images, scoped by agencyId.
    // A user can only upload images for a property within their own agency.
    match /agencies/{agencyId}/properties/{propertyId}/{imageName} {
      allow write: if isUserInAgency(agencyId);
    }
  }
}
