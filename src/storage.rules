rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Allow public read access to all files. This is generally safe for property images.
    match /{allPaths=**} {
      allow read: if true;
    }

    // Secure write rule for property images, scoped by agencyId.
    // A user must be authenticated to upload files.
    // Security is further handled by the unguessable, structured path generated by the application logic.
    match /agencies/{agencyId}/properties/{propertyId}/{imageName} {
      allow write: if request.auth != null;
    }
  }
}
