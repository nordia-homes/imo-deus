rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    
    function isUserInAgency(agencyId) {
      let agencyDoc = get(/databases/$(database)/documents/agencies/$(agencyId));
      return request.auth != null &&
             exists(/databases/$(database)/documents/agencies/$(agencyId)) &&
             'agentIds' in agencyDoc.data &&
             agencyDoc.data.agentIds is list &&
             request.auth.uid in agencyDoc.data.agentIds;
    }
    
    function isUserAdminForAgency(agencyId) {
        let userProfileData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
        return request.auth != null && 
               userProfileData.get('role', '') == 'admin' &&
               userProfileData.get('agencyId', '') == agencyId;
    }

    function userAgencyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    match /agencies/{agencyId} {
      allow get: if true; 
      allow list: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isUserAdminForAgency(agencyId);
      allow delete: if false; 
    }

    match /invites/{inviteId} {
      allow create: if isUserAdminForAgency(request.resource.data.agencyId);
      allow read, delete: if request.auth != null;
    }
    
    match /agencies/{agencyId}/{privateCollection}/{docId}
    where privateCollection in ['contacts', 'tasks', 'reports', 'emails'] {
      allow read, write: if isUserInAgency(agencyId);
    }

    match /agencies/{agencyId}/{publicCollection}/{docId}
    where publicCollection in ['properties', 'viewings'] {
      allow read: if true;
      allow write: if isUserInAgency(agencyId);
    }

    // --- Portal Rules (Corrected for public read and secure writes) ---
    
    match /portals/{portalId} {
        // Anyone with the unguessable link can read the portal data. This is intended.
        allow read: if true;

        // To CREATE, user must be authenticated and creating for their own agency.
        allow create: if request.auth != null
                      && request.resource.data.agencyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId;

        // To DELETE, user must be authenticated and deleting from their own agency.
        allow delete: if request.auth != null
                      && get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId;
        
        // We don't allow general updates to the portal document itself.
        allow update: if false;
    }
    
    match /portals/{portalId}/recommendations/{recommendationId} {
      // Public read access is safe due to unguessable portalId in the path.
      allow read: if true;
      
      // Helper function to check if the acting user is a member of the agency that owns this portal.
      function isAgencyMemberForPortal() {
        let portal = get(/databases/$(database)/documents/portals/$(portalId));
        // Check if user is authenticated and their agency ID matches the portal's agency ID
        return request.auth != null
               && exists(/databases/$(database)/documents/users/$(request.auth.uid))
               && portal.data.agencyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId;
      }
      
      // Helper function to check if the only fields being updated are for client feedback.
      function isClientFeedbackUpdate() {
        // Client is not authenticated, but can only update feedback fields.
        return request.auth == null && 
               request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientFeedback', 'clientComment']);
      }
      
      // An agency member can create or delete recommendations.
      allow create, delete: if isAgencyMemberForPortal();
      
      // An agency member can update anything.
      // A client (unauthenticated) can ONLY update feedback fields.
      allow update: if isAgencyMemberForPortal() || isClientFeedbackUpdate();
    }
  }
}
