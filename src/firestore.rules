rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isUserDoc(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }
    
    function getUserData() {
      return get(isUserDoc(request.auth.uid)).data;
    }

    // --- User Profiles ---
    // A user can read/update their own profile. An admin of the same agency can read it.
    match /users/{userId} {
      allow get: if (isSignedIn() && request.auth.uid == userId) || 
                    (
                      isSignedIn() &&
                      exists(isUserDoc(request.auth.uid)) &&
                      exists(isUserDoc(userId)) &&
                      getUserData().agencyId != null &&
                      getUserData().agencyId == get(isUserDoc(userId)).data.agencyId
                    );
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow list, create, delete: if false;
    }

    // --- Agency Subcollections ---
    // This is the most important rule. To read/write from any agency subcollection,
    // the requesting user must exist and their profile's agencyId must match the agencyId in the path.
    match /agencies/{agencyId}/{allChildren=**} {
      allow read, write: if isSignedIn() && 
                            exists(isUserDoc(request.auth.uid)) &&
                            get(isUserDoc(request.auth.uid)).data.agencyId == agencyId;
    }

    // --- Agency Top-Level Document ---
    match /agencies/{agencyId} {
      // Any authenticated user can get an agency's public details.
      allow get: if true;

      // Only admins of that agency can update it.
      allow update: if isSignedIn() && 
                      exists(isUserDoc(request.auth.uid)) &&
                      getUserData().agencyId == agencyId &&
                      getUserData().role == 'admin';

      // Anyone authenticated can create an agency, as long as they set themselves as owner.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      allow list: if isSignedIn();
      allow delete: if false; // Deleting agencies disabled for safety
    }
    
    // --- Invites ---
    match /invites/{inviteId} {
      // Admins can create invites for their own agency.
      allow create: if isSignedIn() && 
                      exists(isUserDoc(request.auth.uid)) &&
                      getUserData().role == 'admin' &&
                      getUserData().agencyId == request.resource.data.agencyId;
      // Any signed-in user can read an invite (e.g., to accept it) or delete it.
      allow read, delete: if isSignedIn();
    }
    
    // --- Scraper Collection ---
    match /ownerListings/{listingId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // --- Client Portals ---
    match /portals/{portalId} {
      // Anyone with the link can read portal data.
      allow get, list: if true;
      
      // Agency members can create/delete portals for their agency.
      allow create: if isSignedIn() && 
                      exists(isUserDoc(request.auth.uid)) &&
                      getUserData().agencyId == request.resource.data.agencyId;

      allow delete: if isSignedIn() && 
                      exists(/databases/$(database)/documents/portals/$(portalId)) && 
                      exists(isUserDoc(request.auth.uid)) &&
                      getUserData().agencyId == get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId;

      // --- Recommendations Sub-collection ---
      match /recommendations/{recommendationId} {
        // Publicly readable for the client.
        allow get, list: if true;
        
        // Agency members can add/remove recommendations.
        allow create, delete: if isSignedIn() && 
                                exists(/databases/$(database)/documents/portals/$(portalId)) && 
                                exists(isUserDoc(request.auth.uid)) &&
                                getUserData().agencyId == get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId;
                                
        // An agent can update anything. A client (public) can only update feedback.
        allow update: if (isSignedIn() && 
                         exists(/databases/$(database)/documents/portals/$(portalId)) && 
                         exists(isUserDoc(request.auth.uid)) &&
                         getUserData().agencyId == get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId) ||
                        (request.auth == null && request.resource.data.keys().hasOnly(['clientFeedback', 'clientComment']));
      }
    }
  }
}
