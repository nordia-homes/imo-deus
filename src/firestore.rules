rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    // This function is ONLY safe for single-document operations (get, create, update, delete)
    function isUserInAgency(agencyId) {
      // Must first check existence before accessing data
      let agencyPath = /databases/$(database)/documents/agencies/$(agencyId);
      if (!exists(agencyPath)) {
        return false;
      }
      let agencyDoc = get(agencyPath);
      return request.auth != null && (
        request.auth.uid == agencyDoc.data.ownerId ||
        (agencyDoc.data.agentIds != null && request.auth.uid in agencyDoc.data.agentIds)
      );
    }
    
    function isUserAdmin(agencyId) {
      if (request.auth == null) { return false; }
      let userProfilePath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userProfilePath) &&
             get(userProfilePath).data.role == 'admin' &&
             get(userProfilePath).data.agencyId == agencyId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    match /agencies/{agencyId} {
      allow get, list: if true; // Publicly readable
      allow create: if request.auth != null;
      allow update: if isUserAdmin(agencyId);
      allow delete: if false;
    }

    match /invites/{inviteId} {
      allow create: if isUserAdmin(request.resource.data.agencyId);
      allow read, delete: if request.auth != null;
    }
    
    // NOTE: `isUserInAgency` uses `get()`, which is not allowed in `list` rules. 
    // This rule will cause queries on these subcollections to fail.
    // This needs a more advanced fix (e.g., constraining client-side queries).
    match /agencies/{agencyId}/{subcollection}/{docId}
    where subcollection in ['contacts', 'tasks', 'reports', 'emails'] {
      allow get, create, update, delete: if isUserInAgency(agencyId);
      allow list: if isUserInAgency(agencyId); // This will fail.
    }

    match /agencies/{agencyId}/properties/{propertyId} {
        allow get: if resource.data.status == 'Activ' || isUserInAgency(agencyId);
        allow list: if true; // Publicly listable, which is correct.
        allow create, update, delete: if isUserInAgency(agencyId);
    }

    // --- Portal Rules ---
    
    match /portals/{portalId} {
        allow get: if true;
        allow create: if isUserInAgency(request.resource.data.agencyId);
        allow delete: if isUserInAgency(get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId);
    }
    
    match /portals/{portalId}/recommendations/{recommendationId} {
      
      // READ RULE: Allow both `get` and `list` for anyone.
      // The security is based on the unguessable `portalId`. This is the simplest and most robust fix.
      allow read: if true;
      
      // WRITE RULES: Only authenticated users belonging to the agency can write.
      // These are single-doc ops, so get() is safe here.
      function userCanWriteToPortal() {
        let portalPath = /databases/$(database)/documents/portals/$(portalId);
        return request.auth != null &&
               exists(portalPath) &&
               isUserInAgency(get(portalPath).data.agencyId);
      }

      function isClientFeedbackUpdate() {
        // Allows an unauthenticated client to update only feedback fields.
        return request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientFeedback', 'clientComment']);
      }
      
      allow create, delete: if userCanWriteToPortal();
      allow update: if userCanWriteToPortal() || isClientFeedbackUpdate();
    }
  }
}
