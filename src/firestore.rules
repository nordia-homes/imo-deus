rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    // Checks if the user's profile document exists and they are associated with the given agencyId.
    // This is the primary function for authorizing access to agency-specific data.
    function isUserInAgency(agencyId) {
      // Check if the agency document exists before trying to read from it.
      let agencyPath = /databases/$(database)/documents/agencies/$(agencyId);
      if (!exists(agencyPath)) {
        return false;
      }
      let agencyDoc = get(agencyPath).data;
      
      // A user is in the agency if they are the owner OR their UID is in the agentIds list.
      return isAuthenticated() && (
        request.auth.uid == agencyDoc.ownerId || 
        (agencyDoc.agentIds != null && request.auth.uid in agencyDoc.agentIds)
      );
    }
    
    // Checks if the user is an administrator of the given agency.
    function isUserAdmin(agencyId) {
      let userProfilePath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isUserInAgency(agencyId) &&
             exists(userProfilePath) &&
             get(userProfilePath).data.role == 'admin';
    }

    // --- Collection Rules ---

    // USER PROFILES: Users can read and update their own profile.
    match /users/{userId} {
      allow read, update: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated(); // Allow creation upon registration.
    }

    // AGENCIES: Publicly readable. Only admins can update.
    match /agencies/{agencyId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAuthenticated();
      allow update: if isUserAdmin(agencyId);
      allow delete: if false; // Disallow deleting agencies.
    }

    // INVITES: Admins create invites. Any authenticated user can read/delete (to accept).
    match /invites/{inviteId} {
      allow create: if isAuthenticated() && isUserAdmin(request.resource.data.agencyId);
      allow read, delete: if isAuthenticated();
    }
    
    // AGENCY SUBCOLLECTIONS: Only agency members can access.
    match /agencies/{agencyId}/{subcollection}/{docId}
    where subcollection in ['contacts', 'tasks', 'reports', 'emails'] {
      allow read, write: if isUserInAgency(agencyId);
    }

    // PROPERTIES: Publicly readable if active, otherwise restricted to agency members.
    match /agencies/{agencyId}/properties/{propertyId} {
        allow get: if (resource.data.status == 'Activ') || isUserInAgency(agencyId);
        allow list: if true;
        allow create, update, delete: if isUserInAgency(agencyId);
    }

    // --- Portal Rules ---
    
    // PORTAL DOCUMENT: Publicly gettable (for clients), but only agents can create/delete.
    match /portals/{portalId} {
        allow get: if true;
        allow create: if isUserInAgency(request.resource.data.agencyId);
        allow delete: if isUserInAgency(get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId);
    }
    
    // RECOMMENDATIONS SUBCOLLECTION:
    match /portals/{portalId}/recommendations/{recommendationId} {
        // READ: Publicly readable. Security is through the unguessable portalId.
        // This allows both unauthenticated clients and authenticated agents to read.
        allow read: if true;

        // WRITE: For write operations, we verify the user is part of the correct agency.
        function userIsInPortalAgency() {
          let portalDoc = get(/databases/$(database)/documents/portals/$(portalId));
          return exists(/databases/$(database)/documents/portals/$(portalId)) &&
                 isUserInAgency(portalDoc.data.agencyId);
        }

        // CREATE/DELETE: Only agents of the portal's agency can add/remove recommendations.
        allow create, delete: if userIsInPortalAgency();

        // UPDATE: Agents can update anything. Unauthenticated clients can only update feedback fields.
        function isClientFeedbackUpdate() {
            return request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientFeedback', 'clientComment']);
        }
        allow update: if userIsInPortalAgency() || isClientFeedbackUpdate();
    }
  }
}
