rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isUserInAgency(agencyId) {
      if (request.auth == null) {
        return false;
      }
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath) &&
             'agencyId' in get(userDocPath).data &&
             get(userDocPath).data.agencyId == agencyId;
    }
    
    function isUserAdmin(agencyId) {
        if (request.auth == null) {
          return false;
        }
        let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
        return isUserInAgency(agencyId) &&
               'role' in get(userDocPath).data &&
               get(userDocPath).data.role == 'admin';
    }

    function isAddingSelfToAgency(agencyId) {
      if (request.auth == null) {
        return false;
      }
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      if (userDoc.agencyId != agencyId) {
        return false;
      }
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      if (!affectedKeys.hasOnly(['agentIds'])) {
        return false;
      }
      let agentIdsDiff = request.resource.data.agentIds.diff(resource.data.agentIds);
      return agentIdsDiff.added().size() == 1 &&
             agentIdsDiff.added()[0] == request.auth.uid &&
             agentIdsDiff.removed().size() == 0;
    }

    match /users/{userId} {
      allow get: if request.auth != null && (
        request.auth.uid == userId || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
          exists(/databases/$(database)/documents/users/$(userId)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId == get(/databases/$(database)/documents/users/$(userId)).data.agencyId
        )
      );
      allow create, update: if request.auth != null && request.auth.uid == userId;

      match /notifications/{notificationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /agencies/{agencyId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null;
      allow delete: if false;
      allow update: if request.auth != null && (isUserAdmin(agencyId) || isAddingSelfToAgency(agencyId));
    }
    
    match /invites/{inviteId} {
        allow create: if request.auth != null && isUserAdmin(request.resource.data.agencyId);
        allow read, delete: if request.auth != null;
    }

    match /agencies/{agencyId}/properties/{propertyId} {
      // Get: Members can get any property. Public can only get 'Activ' ones.
      allow get: if isUserInAgency(agencyId) || ('status' in resource.data && resource.data.status == 'Activ');

      // List: Members can list all properties. Public can also list, 
      // but the query MUST include `where('status', '==', 'Activ')` to succeed, 
      // as it's enforced by the `get` rule above.
      allow list: if isUserInAgency(agencyId) || request.auth == null;
      
      // Write: Only members can write.
      allow write: if isUserInAgency(agencyId);
    }
    
    // For all other private subcollections, only allow access to agency members.
    match /agencies/{agencyId}/(contacts|tasks|reports|emails|contracts)/{docId} {
      allow read, write: if request.auth != null && isUserInAgency(agencyId);
    }
  }
}
