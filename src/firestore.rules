rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }
    
    // Checks if the user's profile says they belong to the agency.
    // This is safer for read/list operations.
    function isUserInAgency(agencyId) {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() &&
             exists(userDocPath) &&
             'agencyId' in get(userDocPath).data &&
             get(userDocPath).data.agencyId == agencyId;
    }

    // Checks if the user is an admin of the specified agency.
    function isUserAdminForAgency(agencyId) {
        let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
        // An admin must be a member of the agency and have the 'admin' role.
        return isUserInAgency(agencyId) &&
               'role' in get(userDocPath).data &&
               get(userDocPath).data.role == 'admin';
    }

    // --- User Profiles ---
    match /users/{userId} {
      // A user can read another user's profile ONLY IF they are both in the same agency.
      function canReadOtherUsers() {
        let requestingUserDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
        let targetUserDocPath = /databases/$(database)/documents/users/$(userId);
        
        // This rule is robust against non-existent user documents.
        return exists(requestingUserDocPath) &&
               exists(targetUserDocPath) &&
               'agencyId' in get(requestingUserDocPath).data &&
               'agencyId' in get(targetUserDocPath).data &&
               get(requestingUserDocPath).data.agencyId != null &&
               get(requestingUserDocPath).data.agencyId == get(targetUserDocPath).data.agencyId;
      }

      // A user can read their own profile, or another user's profile if they are in the same agency.
      allow get: if isSignedIn() && (request.auth.uid == userId || canReadOtherUsers());

      // Users can create and update their own profile.
      allow update, create: if isSignedIn() && request.auth.uid == userId;
      // No one can list all users or delete them from the client.
      allow list, delete: if false;
    }

    // --- Invites ---
    match /invites/{inviteId} {
      // Admins can create invites for their own agency.
      allow create: if isUserAdminForAgency(request.resource.data.agencyId);
      // Any signed-in user can read an invite (e.g., to accept it upon registration)
      // or delete it after accepting.
      allow read, delete: if isSignedIn();
    }
    
    // --- Owner Listings (from scraper) ---
    match /ownerListings/{listingId} {
      // Any authenticated user can read the scraped listings.
      // Writes should only happen from the backend service (scraper function).
      allow read: if isSignedIn();
      allow write: if false; // Deny client-side writes for safety
    }

    // --- Agencies ---
    match /agencies/{agencyId} {
      // Public read access is needed for the public website and for some rules to work.
      allow get: if true;
      allow list: if isSignedIn();
      // An owner or admin can update their own agency's details.
      // Safely access ownerId.
      allow update: if isUserAdminForAgency(agencyId) || (exists(/databases/$(database)/documents/agencies/$(agencyId)) && get(/databases/$(database)/documents/agencies/$(agencyId)).data.ownerId == request.auth.uid);
       // A user can create an agency, ensuring they set themselves as the owner.
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      // Deleting agencies is disabled for safety.
      allow delete: if false;

      // --- Agency Sub-collections ---
      // For all sub-collections, a user can read/write if they are part of that agency.
      // This is a simpler and more robust rule than checking the user's own profile.
      match /contacts/{contactId}   { allow read, write: if isUserInAgency(agencyId); }
      match /tasks/{taskId}         { allow read, write: if isUserInAgency(agencyId); }
      match /reports/{reportId}     { allow read, write: if isUserInAgency(agencyId); }
      match /emails/{emailId}       { allow read, write: if isUserInAgency(agencyId); }
      match /viewings/{viewingId}   { allow read, write: if isUserInAgency(agencyId); }

      // Properties are publicly readable but only writable by agency members.
      match /properties/{propertyId} {
        allow get, list: if true;
        allow create, update, delete: if isUserInAgency(agencyId);
      }
    }

    // --- Client Portals ---
    match /portals/{portalId} {
      // Anyone with the link can read the portal data.
      allow get, list: if true;
      
      // Only a verified member of the agency can create a portal.
      allow create: if isUserInAgency(request.resource.data.agencyId);
      
      // Only a verified member of the agency can delete the portal.
      // Safely access agencyId from portal doc.
      allow delete: if exists(/databases/$(database)/documents/portals/$(portalId)) && isUserInAgency(get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId);

      // --- Portal Recommendations Sub-collection ---
      match /recommendations/{recommendationId} {
        // Publicly readable for the client.
        allow get, list: if true;
        
        // Only agency members can add/remove recommendations.
        allow create, delete: if exists(/databases/$(database)/documents/portals/$(portalId)) && isUserInAgency(get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId);

        // An agent can update anything. A client (public) can only update feedback.
        allow update: if (exists(/databases/$(database)/documents/portals/$(portalId)) && isUserInAgency(get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId)) ||
                        (request.auth == null && request.resource.data.keys().hasOnly(['clientFeedback', 'clientComment']));
      }
    }
  }
}
