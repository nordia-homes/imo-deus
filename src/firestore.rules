rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isUserInAgency(agencyId) {
      if (request.auth == null) {
        return false;
      }
      let agencyDocPath = /databases/$(database)/documents/agencies/$(agencyId);
      if (!exists(agencyDocPath)) {
        return false;
      }
      let agencyData = get(agencyDocPath).data;
      // An agent is part of the agency if they are the owner OR their ID is in the agentIds list.
      return request.auth.uid == agencyData.ownerId || (
             'agentIds' in agencyData && 
             request.auth.uid in agencyData.agentIds
      );
    }
    
    function isUserAdmin(agencyId) {
        if (request.auth == null) {
          return false;
        }
        let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
        // An admin must first be part of the agency
        return isUserInAgency(agencyId) &&
               exists(userDocPath) &&
               'role' in get(userDocPath).data &&
               get(userDocPath).data.role == 'admin';
    }

    function isAddingSelfToAgency(agencyId) {
      if (request.auth == null) {
        return false;
      }
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      if (userDoc.agencyId != agencyId) {
        return false;
      }
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      if (!affectedKeys.hasOnly(['agentIds'])) {
        return false;
      }
      let agentIdsDiff = request.resource.data.agentIds.diff(resource.data.agentIds);
      return agentIdsDiff.added().size() == 1 &&
             agentIdsDiff.added()[0] == request.auth.uid &&
             agentIdsDiff.removed().size() == 0;
    }

    function userIsInPortalAgency(portalId) {
      let portalPath = /databases/$(database)/documents/portals/$(portalId);
      if (!exists(portalPath)) {
        return false;
      }
      let portalData = get(portalPath).data;
      if (!('agencyId' in portalData)) {
        return false;
      }
      return isUserInAgency(portalData.agencyId);
    }

    match /users/{userId} {
      allow get: if request.auth != null && (
        request.auth.uid == userId || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
          exists(/databases/$(database)/documents/users/$(userId)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId == get(/databases/$(database)/documents/users/$(userId)).data.agencyId
        )
      );
      allow create, update: if request.auth != null && request.auth.uid == userId;

    }

    match /agencies/{agencyId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null;
      allow delete: if false;
      allow update: if request.auth != null && (isUserAdmin(agencyId) || isAddingSelfToAgency(agencyId));
    }
    
    match /invites/{inviteId} {
        allow create: if request.auth != null && isUserAdmin(request.resource.data.agencyId);
        allow read, delete: if request.auth != null;
    }

    match /portals/{portalId} {
      allow get: if true;
      allow create: if request.auth != null && isUserInAgency(request.resource.data.agencyId);
      allow delete: if request.auth != null && isUserInAgency(resource.data.agencyId);
    }

    match /portals/{portalId}/recommendations/{recommendationId} {
      allow read: if request.auth == null || userIsInPortalAgency(portalId);
      allow create, delete: if userIsInPortalAgency(portalId);
      allow update: if userIsInPortalAgency(portalId) || 
          (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientFeedback', 'clientComment']));
    }

    match /agencies/{agencyId}/properties/{propertyId} {
      allow get: if isUserInAgency(agencyId) || ('status' in resource.data && resource.data.status == 'Activ');
      allow list: if isUserInAgency(agencyId) || request.auth == null;
      allow write: if isUserInAgency(agencyId);
    }
    
    match /agencies/{agencyId}/(contacts|tasks|reports|emails|contracts)/{docId} {
      allow read, write: if request.auth != null && isUserInAgency(agencyId);
    }
  }
}
