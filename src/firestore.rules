rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    
    // Checks if a user belongs to an agency, either as owner or as an agent in the agentIds list.
    function isUserInAgency(agencyId) {
      let agencyDocData = get(/databases/$(database)/documents/agencies/$(agencyId)).data;
      let isOwner = request.auth.uid == agencyDocData.ownerId;
      // Check if agentIds exists and is a list before checking membership
      let isAgent = 'agentIds' in agencyDocData &&
                    agencyDocData.agentIds is list &&
                    request.auth.uid in agencyDocData.agentIds;
      return request.auth != null && (isOwner || isAgent);
    }
    
    // Checks if the user has an 'admin' role for the given agency.
    function isUserAdminForAgency(agencyId) {
        let userProfileData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
        return request.auth != null && 
               userProfileData.get('role', '') == 'admin' &&
               userProfileData.get('agencyId', '') == agencyId;
    }

    // Gets the current user's agency ID from their profile.
    function userAgencyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.agencyId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    match /agencies/{agencyId} {
      allow get: if true; // Publicly readable for public pages
      allow list: if request.auth != null; // Only authenticated users can list agencies
      allow create: if request.auth != null;
      allow update: if isUserAdminForAgency(agencyId);
      allow delete: if false; // Agencies cannot be deleted
    }

    match /invites/{inviteId} {
      allow create: if isUserAdminForAgency(request.resource.data.agencyId);
      allow read, delete: if request.auth != null;
    }
    
    // Rule for private agency data
    match /agencies/{agencyId}/{privateCollection}/{docId}
    where privateCollection in ['contacts', 'tasks', 'reports', 'emails'] {
      // These collections are private to agency members.
      allow read, write: if isUserInAgency(agencyId);
    }

    // Rule for public-facing agency data
    match /agencies/{agencyId}/{publicCollection}/{docId}
    where publicCollection in ['properties', 'viewings'] {
      // Allow public read for properties and viewings (for public websites and portals).
      allow read: if true;
      // Write operations remain secure to agency members.
      allow write: if isUserInAgency(agencyId);
    }

    // --- Portal Rules ---
    
    match /portals/{portalId} {
        // The portal document is public to anyone with the link (unguessable ID).
        allow read: if true;
        
        // Allow creating/updating if the user is authenticated and the portal's agencyId
        // matches the agencyId in the user's own profile.
        allow write: if request.auth != null && request.resource.data.agencyId == userAgencyId();
        
        // Allow deleting if the user is authenticated and the portal's agencyId
        // (from the existing document) matches the agencyId in the user's profile.
        allow delete: if request.auth != null && resource.data.agencyId == userAgencyId();
    }
    
    match /portals/{portalId}/recommendations/{recommendationId} {
      // Public read access is safe due to unguessable portalId in the path.
      allow read: if true;
      
      // WRITE RULES
      function userCanWriteToPortal() {
        let portalDoc = get(/databases/$(database)/documents/portals/$(portalId));
        return request.auth != null &&
               exists(/databases/$(database)/documents/portals/$(portalId)) &&
               isUserInAgency(portalDoc.data.agencyId);
      }

      function isClientFeedbackUpdate() {
        return request.auth == null && 
               request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientFeedback', 'clientComment']);
      }
      
      allow create, delete: if userCanWriteToPortal();
      allow update: if userCanWriteToPortal() || isClientFeedbackUpdate();
    }
  }
}
