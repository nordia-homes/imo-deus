rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isUserProfile(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isUserInAgency(agencyId) {
      return isSignedIn() &&
             isUserProfile(request.auth.uid) &&
             'agencyId' in getUserData(request.auth.uid) &&
             getUserData(request.auth.uid).agencyId == agencyId;
    }

    function isUserAdminForAgency(agencyId) {
       return isUserInAgency(agencyId) &&
              'role' in getUserData(request.auth.uid) &&
              getUserData(request.auth.uid).role == 'admin';
    }

    function isPublicPreferencesUpdate(agencyId, contactId) {
      // Public form update must be unauthenticated
      if (request.auth != null) {
        return false;
      }
      
      // Check for the validation token
      if (!('validationLinkId' in request.resource.data)) {
        return false;
      }
      
      let linkId = request.resource.data.validationLinkId;
      
      // Validate the token exists and maps to the correct contact/agency
      if (!exists(/databases/$(database)/documents/buyer-preferences-links/$(linkId))) {
        return false;
      }
      let linkData = get(/databases/$(database)/documents/buyer-preferences-links/$(linkId)).data;
      if (linkData.contactId != contactId || linkData.agencyId != agencyId) {
        return false;
      }
      
      // Ensure only the allowed fields are being modified by the public form
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys;
      let allowedFields = ['budget', 'city', 'generalZone', 'zones', 'preferences', 'interactionHistory', 'validationLinkId'];
      
      return changedKeys.hasOnly(allowedFields);
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow get: if isUserAdminForAgency(getUserData(userId).agencyId);
    }
    
    // --- Specific Rule for Contacts ---
    match /agencies/{agencyId}/contacts/{contactId} {
      allow get, list, create, delete: if isUserInAgency(agencyId);
      allow update: if isUserInAgency(agencyId) || isPublicPreferencesUpdate(agencyId, contactId);
    }

    // --- Generic Rule for other Agency Subcollections ---
    match /agencies/{agencyId}/{collection}/{docId} 
      where collection != 'contacts' {
      allow get, write: if isUserInAgency(agencyId);
      allow list: if isUserInAgency(agencyId);
    }

    // --- Agency Top-Level Document ---
    match /agencies/{agencyId} {
      allow get: if isUserInAgency(agencyId);
      allow list: if isSignedIn();
      allow update: if isUserAdminForAgency(agencyId);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if false; 
    }
    
    // --- Invites ---
    match /invites/{inviteId} {
      allow create: if isUserAdminForAgency(request.resource.data.agencyId);
      allow read, delete: if isSignedIn();
    }
    
    // --- Scraper Collection ---
    match /ownerListings/{listingId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // --- Client Portals ---
    match /portals/{portalId} {
      // Anyone with the link can read portal and recommendation data.
      allow get, list: if true;
      
      // Agency members can create/delete portals for contacts in their agency.
      allow create, delete: if isSignedIn() && isUserInAgency(request.resource.data.agencyId);

      // --- Recommendations Sub-collection ---
      match /recommendations/{recommendationId} {
        // Publicly readable for the client with the portal link.
        allow get, list: if true;
        
        // Agency members can add/delete recommendations.
        allow create, delete: if isSignedIn() && isUserInAgency(get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId);
                                
        // An agent can update anything. A client (public/anonymous) can only update feedback fields.
        allow update: if (isSignedIn() && isUserInAgency(get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId)) ||
                        (request.auth == null && request.resource.data.keys().hasOnly(['clientFeedback', 'clientComment']));
      }
    }

    // --- Buyer Preferences Link ---
    match /buyer-preferences-links/{linkId} {
      allow read: if true; // Public read is needed for the form page and for the validation in security rules.
      allow create: if isUserAdminForAgency(request.resource.data.agencyId);
      allow write: if false; // Links are immutable once created.
    }
  }
}
