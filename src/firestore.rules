rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    // Checks if the user is authenticated.
    function isAuthenticated() {
      return request.auth != null;
    }

    // Checks if the user's profile document exists and they are associated with the given agencyId.
    // This is the primary function for authorizing access to agency-specific data.
    function isUserInAgency(agencyId) {
      let userProfilePath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() &&
             exists(userProfilePath) &&
             get(userProfilePath).data.agencyId == agencyId;
    }
    
    // Checks if the user is an administrator of the given agency.
    // An admin must be a user in the agency and have the 'admin' role.
    function isUserAdmin(agencyId) {
      let userProfilePath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isUserInAgency(agencyId) &&
             get(userProfilePath).data.role == 'admin';
    }

    // --- Collection Rules ---

    // USER PROFILES: Users can read and update their own profile.
    match /users/{userId} {
      allow read, update: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated(); // Allow creation upon registration.
    }

    // AGENCIES: Any authenticated user can create an agency. Only admins can update it. Publicly readable.
    match /agencies/{agencyId} {
      allow get: if true; // Publicly readable for public pages.
      allow list: if true; // Publicly listable for public pages.
      allow create: if isAuthenticated();
      allow update: if isUserAdmin(agencyId);
      allow delete: if false; // Disallow deleting agencies.
    }

    // INVITES: Admins can create invites. Any authenticated user can read them (to check if they've been invited).
    match /invites/{inviteId} {
      allow create: if isAuthenticated() && isUserAdmin(request.resource.data.agencyId);
      allow read, delete: if isAuthenticated(); // Read to check for invite, delete upon registration.
    }
    
    // AGENCY SUBCOLLECTIONS: Any user within the agency can perform all operations on these resources.
    match /agencies/{agencyId}/{subcollection}/{docId}
    where subcollection in ['contacts', 'tasks', 'reports', 'emails', 'contracts'] {
      allow read, write: if isUserInAgency(agencyId);
    }

    // PROPERTIES: Publicly readable if active, otherwise restricted to agency members.
    match /agencies/{agencyId}/properties/{propertyId} {
        allow get: if (resource.data.status == 'Activ') || isUserInAgency(agencyId);
        allow list: if true; // Allow listing for public property pages.
        allow create, update, delete: if isUserInAgency(agencyId);
    }

    // --- Portal Rules ---
    
    // PORTALS: Only agency members can create/delete portals. Publicly readable via unguessable ID.
    match /portals/{portalId} {
        allow get: if true;
        allow create: if isAuthenticated() && isUserInAgency(request.resource.data.agencyId);
        allow delete: if isAuthenticated() && isUserInAgency(resource.data.agencyId);
    }

    // RECOMMENDATIONS: 
    // Read: Anyone (clients with link, agents) can read. Security is the unguessable portal ID.
    // Create/Delete: Only agency members can add/remove properties.
    // Update: Agency members can update everything. Clients (unauthenticated) can only update feedback fields.
    match /portals/{portalId}/recommendations/{recommendationId} {
        function isClientFeedbackUpdate() {
            return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientFeedback', 'clientComment']);
        }
        
        function getPortalAgencyId() {
          return get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId;
        }

        allow read: if true;
        allow create, delete: if exists(/databases/$(database)/documents/portals/$(portalId)) && 
                                isUserInAgency(getPortalAgencyId());
        allow update: if (exists(/databases/$(database)/documents/portals/$(portalId)) && 
                         isUserInAgency(getPortalAgencyId())) || isClientFeedbackUpdate();
    }
  }
}
