rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isUserInAgency(agencyId) {
      let agencyDoc = get(/databases/$(database)/documents/agencies/$(agencyId));
      // Ensure the agency document exists and the user's UID is in the agentIds list.
      return request.auth != null &&
             exists(/databases/$(database)/documents/agencies/$(agencyId)) &&
             'agentIds' in agencyDoc.data &&
             agencyDoc.data.agentIds is list &&
             request.auth.uid in agencyDoc.data.agentIds;
    }
    
    function isUserAdminForAgency(agencyId) {
        let userProfile = get(/databases/$(database)/documents/users/$(request.auth.uid));
        // Ensure user profile exists and they have the 'admin' role for the given agency.
        return request.auth != null &&
               exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               userProfile.data.role == 'admin' &&
               userProfile.data.agencyId == agencyId;
    }

    // --- Collection Rules ---

    // Users can only read/update their own profile. They can create it upon signup.
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Agency details are public for branding on portals/websites.
    // Listing all agencies is restricted to authenticated users.
    // Only admins of that agency can update it.
    match /agencies/{agencyId} {
      allow get: if true; 
      allow list: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      allow update: if isUserAdminForAgency(agencyId);
      allow delete: if false; // Agencies should not be deleted.
    }

    // Invites can only be created by an agency admin.
    // Any authenticated user can read/delete them (e.g., to accept an invite).
    match /invites/{inviteId} {
      allow create: if isUserAdminForAgency(request.resource.data.agencyId);
      allow read, delete: if request.auth != null;
    }
    
    // Private agency data (contacts, tasks, etc.) is only accessible to members of that agency.
    match /agencies/{agencyId}/contacts/{contactId} {
        allow read, write: if isUserInAgency(agencyId);
    }
    
    match /agencies/{agencyId}/tasks/{taskId} {
        allow read, write: if isUserInAgency(agencyId);
    }

    // Publicly readable property listings. Only agency members can write.
    match /agencies/{agencyId}/properties/{propertyId} {
      allow get: if true;
      allow list, create, update, delete: if isUserInAgency(agencyId);
    }
    
    match /agencies/{agencyId}/viewings/{viewingId} {
        allow read, write: if isUserInAgency(agencyId);
    }

    // --- Portal Rules ---
    match /portals/{portalId} {
        // Anyone with the (unguessable) link can read the portal.
        allow get, list: if true;

        // Only an agent belonging to the correct agency can create or update a portal.
        allow write: if request.auth != null && isUserInAgency(request.resource.data.agencyId);

        // Only an agent belonging to the correct agency can delete a portal.
        allow delete: if request.auth != null && isUserInAgency(resource.data.agencyId);
    }
    
    match /portals/{portalId}/recommendations/{recommendationId} {
      // Recommendations are publicly readable via the portal link.
      allow get, list: if true;
      
      // An agent of the portal's agency can add/remove recommendations.
      allow create, delete: if request.auth != null && isUserInAgency(get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId);
      
      // The client (unauthenticated) can only update their own feedback.
      // An agent can update anything.
      allow update: if (request.auth != null && isUserInAgency(get(/databases/$(database)/documents/portals/$(portalId)).data.agencyId)) ||
                      (request.auth == null && request.resource.data.keys().hasOnly(['clientFeedback', 'clientComment']));
    }
  }
}
