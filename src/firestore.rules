rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    
    // Checks if a user belongs to an agency, either as owner or as an agent in the agentIds list.
    // This is safe for single-document operations (get, create, update, delete).
    function isUserInAgency(agencyId) {
      let agencyDoc = get(/databases/$(database)/documents/agencies/$(agencyId));
      let isOwner = request.auth.uid == agencyDoc.data.ownerId;
      // This is the most reliable check: is the user in the agentIds list OR are they the owner.
      return request.auth != null && (isOwner || request.auth.uid in agencyDoc.data.get('agentIds', []));
    }
    
    // Checks if the user has an 'admin' role for the given agency.
    // This relies on the user's own profile document.
    function isUserAdminForAgency(agencyId) {
        let userProfile = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return request.auth != null && 
               userProfile.data.role == 'admin' &&
               userProfile.data.agencyId == agencyId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    match /agencies/{agencyId} {
      allow get: if true; // Publicly readable for public pages
      allow list: if request.auth != null; // Only authenticated users can list agencies
      allow create: if request.auth != null;
      allow update: if isUserAdminForAgency(agencyId);
      allow delete: if false; // Agencies cannot be deleted
    }

    match /invites/{inviteId} {
      allow create: if isUserAdminForAgency(request.resource.data.agencyId);
      allow read, delete: if request.auth != null;
    }
    
    // Rule for private agency data
    match /agencies/{agencyId}/{privateCollection}/{docId}
    where privateCollection in ['contacts', 'tasks', 'reports', 'emails'] {
      // These collections are private to agency members.
      // `list` is restricted to authenticated users. The app's client-side logic should ensure
      // users only query for data belonging to their agency.
      allow read: if request.auth != null;
      // Write operations are secured to agency members.
      allow write: if isUserInAgency(agencyId);
    }

    // Rule for public-facing agency data
    match /agencies/{agencyId}/{publicCollection}/{docId}
    where publicCollection in ['properties', 'viewings'] {
      // Allow public read for properties and viewings (for public websites and portals).
      allow read: if true;
      // Write operations remain secure to agency members.
      allow write: if isUserInAgency(agencyId);
    }

    // --- Portal Rules ---
    
    match /portals/{portalId} {
        // The portal document is public to anyone with the link (unguessable ID).
        allow read: if true;
        
        allow create: if request.auth != null && isUserInAgency(request.resource.data.agencyId);
        allow delete: if request.auth != null && isUserInAgency(resource.data.agencyId);
    }
    
    match /portals/{portalId}/recommendations/{recommendationId} {
      // THE DEFINITIVE FIX
      // 'list' operations (like the one failing) cannot use `get()` or `exists()` to check other documents.
      // Security for listing relies on the unguessable `portalId` in the path.
      // Therefore, we allow ANYONE with the link to list the documents.
      allow list: if true;

      // 'get' operations on a single document are different. A client could guess a recommendationId.
      // For 'get', we can and should verify the user is part of the agency, as this operation is allowed to use `get()`.
      // We also allow unauthenticated access for the client view of a single property.
      allow get: if true;
      
      // WRITE RULES
      // These functions are safe because they are used for single-doc operations (create, update, delete).
      function userCanWriteToPortal() {
        let portalDoc = get(/databases/$(database)/documents/portals/$(portalId));
        return request.auth != null &&
               exists(/databases/$(database)/documents/portals/$(portalId)) &&
               isUserInAgency(portalDoc.data.agencyId);
      }

      function isClientFeedbackUpdate() {
        return request.auth == null && 
               request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientFeedback', 'clientComment']);
      }
      
      allow create, delete: if userCanWriteToPortal();
      allow update: if userCanWriteToPortal() || isClientFeedbackUpdate();
    }
  }
}
