rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    match /{allPaths=**} {
      // Allow read access to all files. This is generally safe for public
      // assets like property images. Anyone with the URL can view.
      allow read: if true;
    }
    
    // Restrict writes to the 'properties' folder to only authenticated users.
    // This is more secure than a global write rule and sufficient for our app,
    // as only legitimate users (agents) will be adding properties.
    match /properties/{agencyId}/{userId}/{propertyId}/{imageName} {
      allow write: if request.auth != null;
    }
  }
}
