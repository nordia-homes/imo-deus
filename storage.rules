rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    match /{allPaths=**} {
      // Allow read access to all files. This is generally safe for public
      // assets like property images. Anyone with the URL can view.
      allow read: if true;
    }
    
    // Restrict writes to the 'properties' folder to only authenticated users.
    // The propertyId is unguessable, providing security by obscurity for the path.
    // The rule ensures only logged-in users can attempt to write.
    match /properties/{propertyId}/{imageName} {
      allow write: if request.auth != null;
    }
  }
}
