rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public reads for all property images
    match /properties/{agencyId}/{propertyId}/{allPaths=**} {
      allow read: if true;
    }

    // Allow writes only for authenticated users who are part of the agency
    // This rule checks the user's agencyId from their Firestore profile document
    match /properties/{agencyId}/{propertyId}/{fileName} {
      allow write: if request.auth != null &&
                   exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
                   get(/databases/(default)/documents/users/$(request.auth.uid)).data.agencyId == agencyId;
    }
  }
}
